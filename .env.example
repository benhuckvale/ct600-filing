# Government Gateway credentials for TIL and live submission.
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

HMRC_SENDER_ID=your-gateway-username
HMRC_PASSWORD=your-gateway-password

# Vendor ID assigned by HMRC SDST when you registered as a developer.
# Leave as 0000 if you haven't registered.
HMRC_VENDOR_ID=0000
